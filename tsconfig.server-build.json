{
  "extends": "./tsconfig.node.json",
  "compilerOptions": {
    "noEmit": false,
    "composite": false,
    "outDir": "dist/server",
    "rootDir": "src/server",
    "declaration": false,
    "sourceMap": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext"
  },
  "include": ["src/server/**/*.ts"],
  "exclude": ["src/server/**/*.test.ts"]
}
